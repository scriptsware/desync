-- Loading Logic
ActivateButton.MouseButton1Click:Connect(function()
    if isActivating then return end
    isActivating = true
    local startTime = tick()
    local duration = 5
    
    task.spawn(function()
        local dots = ""
        while isActivating do
            dots = dots .. "."
            if #dots > 3 then dots = "" end
            local elapsed = tick() - startTime
            
            -- Stage Text Logic
            local baseText = "Initializing"
            if elapsed >= 45 then baseText = "Finishing up"
            elseif elapsed >= 30 then baseText = "Injecting"
            elseif elapsed >= 20 then baseText = "Downloading raknet files"
            elseif elapsed >= 8 then baseText = "Analyzing game files"
            end
            
            -- Final State check within loop
            if elapsed >= duration then
                ActivateButton.Text = "Done!"
                break
            else
                ActivateButton.Text = baseText .. dots
            end
            
            task.wait(0.5)
        end
    end)
    
    LoadingBar:TweenSize(UDim2.new(1, 0, 1, 0), "Linear", "In", duration)
    
    task.wait(duration)
    isActivating = false
    LoadingBar.Visible = false
    ActivateButton.BackgroundColor3 = Color3.fromRGB(55, 255, 100)
    ActivateButton.BackgroundTransparency = 0.7
end)

