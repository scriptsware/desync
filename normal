-- Original Logic Hook
raknet.add_send_hook(function(packet)
    if active and packet.PacketId == 0x1B then
        local data = packet.AsBuffer
        if data then
            buffer.writeu32(data, 1, 0xFFFFFFFF)
            packet:SetData(data)
        end
    end
end)

